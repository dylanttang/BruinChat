# Copy to .env and set your API URL (not committed to git)
# Physical device: use your computer's local IP, e.g. http://192.168.1.100:3000
# Emulator/same machine: use http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# Optional, depending on platform/client setup
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
