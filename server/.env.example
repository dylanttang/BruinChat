PORT=3000
# Replace with your Atlas URI - never commit real credentials
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/bruinchat?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# Optional, depending on which clients your Expo app uses
# GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
# Optional: your machine's URL for mobile testing (e.g. http://192.168.1.100:3000) - only used in server logs
# SERVER_PUBLIC_URL=http://YOUR_IP:3000
